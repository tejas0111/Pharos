# Pharos Deployment Environment
# Copy this file to .env and fill in your values

# Required: deployer wallet private key (never commit the real .env file)
PRIVATE_KEY=0x...

# RPC URLs (defaults to public endpoints if unset)
PHAROS_TESTNET_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_MAINNET_RPC_URL=https://rpc.pharos.xyz
PHAROS_TESTNET_V2_RPC_URL=https://testnet.dplabs-internal.com
PHAROS_DEVNET_RPC_URL=https://devnet.dplabs-internal.com

# PharosScan API key for contract verification
ETHERSCAN_API_KEY=your-api-key-here

# ZAN API key (alternative RPC provider)
ZAN_API_KEY=your-api-key-here

# Deployer address (for verification scripts)
DEPLOYER_ADDRESS=0x...

# Optional: contract-specific constructor args
INITIAL_SUPPLY=1000000000000000000000000
TOKEN_NAME=MyToken
TOKEN_SYMBOL=MTK
