# Pharos Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit the .env file to source control.

# Network RPC URLs
PHAROS_TESTNET_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_MAINNET_RPC_URL=https://rpc.pharos.xyz

# Private Key (Mandatory for on-chain actions)
# Format: 0x...
PRIVATE_KEY=

# Explorer API Keys (For verification)
PHAROSSCAN_API_KEY=

# Optional: Other configuration
# ETHERSCAN_API_KEY=
