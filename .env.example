# Pharos Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit the .env file to source control.

# Network RPC URLs
PHAROS_TESTNET_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_MAINNET_RPC_URL=https://rpc.pharos.xyz

# Private Key (Mandatory for on-chain actions: deploy, transfer, send)
# Format: 0x...
PRIVATE_KEY=

# Explorer API Keys (For contract verification on PharosScan)
# Mainnet verification: PHAROSSCAN_API_KEY required; Testnet (Blockscout): no key needed
PHAROSSCAN_API_KEY=
PHAROSSCAN_MAINNET_API_URL=https://www.pharosscan.xyz/api
PHAROSSCAN_TESTNET_API_URL=https://atlantic.pharosscan.xyz/api

# Token deployment defaults (used by script/DeployERC20.s.sol)
TOKEN_NAME=Pharos Token
TOKEN_SYMBOL=PHT
INITIAL_SUPPLY=1000000000000000000000000000

# Pharos MCP Server
# Master subskill SKILL.md for routing and orchestration — loaded automatically by the agent.
# No additional env vars required for the MCP server beyond PRIVATE_KEY and RPC URLs above.

# ─── New Contract Deployments ──────────────────────
# StakingPool
STAKING_TOKEN=0x...
REWARD_TOKEN=0x...
REWARD_RATE=1000000000000000000
REWARD_DURATION=2592000

# RWAToken
TOKEN_NAME=PharosRWAToken
TOKEN_SYMBOL=PRWA
TOKEN_MAX_SUPPLY=1000000000000000000000000000

# SimpleLender
COLLATERAL_TOKEN=0x...
BORROW_TOKEN=0x...
INTEREST_RATE=317097920

# DEXPool
TOKEN_A=0x...
TOKEN_B=0x...

# ─── Pacific Mainnet (for deployment) ──────────────────────────────────
# Only needed when deploying to mainnet. Get PROS from an exchange.
# PACIFIC_PRIVATE_KEY=0x...
# PACIFIC_RPC_URL=https://rpc.pharos.xyz
